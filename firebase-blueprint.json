{
  "entities": {
    "User": {
      "title": "User",
      "description": "Application user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "TestResult": {
      "title": "Test Result",
      "description": "Result of a TMT test or training session",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "testType": { "type": "string", "enum": ["TMT-A", "TMT-B", "TMT-B-AR", "TRAINING", "TMT-B-AR-TRAINING"] },
        "level": { "type": "integer" },
        "timeInSeconds": { "type": "number" },
        "errors": { "type": "integer" },
        "timestamp": { "type": "string", "format": "date-time" },
        "rawPath": { "type": "string", "description": "JSON string of the path taken" },
        "analysis": {
          "type": "object",
          "properties": {
            "interpretation": { "type": "string" },
            "recommendations": { "type": "array", "items": { "type": "string" } }
          }
        }
      },
      "required": ["uid", "testType", "timeInSeconds", "errors", "timestamp"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/results/{resultId}": {
      "schema": "TestResult",
      "description": "Test results for all users"
    }
  }
}
